---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline is:global>
  :root {
    /* Tu nueva paleta basada en el logo (Hexágonos) */
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #00BCD4;    /* Cian del logo */
    --aw-color-secondary: #0097A7;  /* Cian oscuro para contraste */
    --aw-color-accent: #FFC107;     /* Amarillo/Ámbar de la abeja */

    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: #F0F9FA;    /* Fondo Cian Pastel muy suave */

    --aw-color-bg-page-dark: #030620;
  }

  .dark {
    --aw-color-primary: #00BCD4;
    --aw-color-secondary: #00838F;
    --aw-color-accent: #FFB300;

    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: #030620;
  }
</style>